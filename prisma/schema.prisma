generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Modoule
enum UserStatus {
  INACTIVE
  ACTIVE
  BLOCKED
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  password        String?
  country         String?
  timezone        String?
  name            String?
  roleId          String
  status          UserStatus  @default(INACTIVE) // Status of the invitation
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastSignInAt    DateTime?
  emailVerifiedAt DateTime?
  isTrashed       Boolean     @default(false)
  avatar          String?
  invitedByUserId String?
  isProtected     Boolean     @default(false) // Prevents deletion/modification
  role            UserRole    @relation(fields: [roleId], references: [id])
  systemLog       SystemLog[]
  accounts        Account[]
  Session         Session[]

  // Indexes for efficient querying
  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
}

model UserRole {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String               @unique
  description     String?
  isTrashed       Boolean              @default(false)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  isProtected     Boolean              @default(false)
  isDefault       Boolean              @default(false)
  users           User[]
  permissions     UserRolePermission[]
}

model UserPermission {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String
  description     String?
  createdByUserId String?
  createdAt       DateTime             @default(now())
  roles           UserRolePermission[]
}

model UserRolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       UserRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission UserPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemLog {
  id          String   @id @default(uuid())
  userId      String
  createdAt   DateTime @default(now())
  entityId    String?
  entityType  String?
  event       String?
  description String?
  ipAddress   String?
  meta        String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SystemSetting {
  id             String  @id @default(uuid())
  name           String  @default("My Company")
  logo           String?
  active         Boolean @default(true)
  address        String?
  websiteURL     String?
  supportEmail   String?
  supportPhone   String?
  language       String  @default("en")
  timezone       String  @default("UTC")
  currency       String  @default("USD")
  currencyFormat String  @default("$ {value}")

  socialFacebook  String?
  socialTwitter   String?
  socialInstagram String?
  socialLinkedIn  String?
  socialPinterest String?
  socialYoutube   String?

  notifyStockEmail               Boolean  @default(true)
  notifyStockWeb                 Boolean  @default(true)
  notifyStockThreshold           Int      @default(10)
  notifyStockRoleIds             String[]
  notifyNewOrderEmail            Boolean  @default(true)
  notifyNewOrderWeb              Boolean  @default(true)
  notifyNewOrderRoleIds          String[]
  notifyOrderStatusUpdateEmail   Boolean  @default(true)
  notifyOrderStatusUpdateWeb     Boolean  @default(true)
  notifyOrderStatusUpdateRoleIds String[]
  notifyPaymentFailureEmail      Boolean  @default(true)
  notifyPaymentFailureWeb        Boolean  @default(true)
  notifyPaymentFailureRoleIds    String[]
  notifySystemErrorFailureEmail  Boolean  @default(true)
  notifySystemErrorWeb           Boolean  @default(true)
  notifySystemErrorRoleIds       String[]
}

// Content hierarchy — Section → Category → Topic → Article
enum SectionStatus {
  active
  archived
}

enum CategoryStatus {
  active
  archived
}

enum TopicStatus {
  active
  archived
}

/// Pipeline stage (single article status)
enum ArticleStatus {
  planning
  research
  writing
  assets
  approval
  scheduling
  publishing
  post_publish
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model Section {
  id                    String        @id @default(uuid())
  name                  String
  slug                  String        @unique
  description           String?
  summary               String?
  icon                  String?
  status                SectionStatus @default(active)
  characterName         String?
  characterBackground   String?
  characterRole         String?
  characterAge          String?
  characterBiography    String?       @db.Text
  characterTone         String?
  characterWritingStyle String?       @db.Text
  characterSampleVoice  String?       @db.Text
  characterPersona      String?       @db.Text
  characterImage        String?
  // WordPress integration — credentials for the author persona of this section
  wpSiteUrl             String?
  wpUsername            String?
  wpAppPassword         String?
  wpAuthorId            Int?
  // Social media template colors — fed into {{COLOR_ACCENT/LIGHT/DARK}} placeholders
  colorAccent           String?
  colorLight            String?
  colorDark             String?
  // Baseline hashtags prepended to AI-generated hashtags for social posts
  socialHashtags        String[]      @default([])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  categories            Category[]

  @@index([status])
  @@index([slug])
}

model Category {
  id           String         @id @default(uuid())
  name         String
  description  String?
  status       CategoryStatus @default(active)
  sectionId    String?
  wpCategoryId Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  section      Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  topics       Topic[]
  articles     Article[]

  @@index([status])
  @@index([sectionId])
}

model Topic {
  id            String      @id @default(uuid())
  name          String
  description   String?
  categoryId    String
  targetKeyword String?
  status        TopicStatus @default(active)
  wpCategoryId  Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  articles      Article[]

  @@index([categoryId])
  @@index([status])
}

model Article {
  id                 String           @id @default(uuid())
  title              String
  /// TipTap / ProseMirror doc: { type: "doc", content: [...] }
  summary            String?
  content            Json?
  featuredImage      String?
  galleryImages      String[]         @default([])
  videoUrl           String?
  isEditorsChoice    Boolean          @default(false)
  views              Int              @default(0)
  likes              Int              @default(0)
  commentsCount      Int              @default(0)
  topicId            String
  categoryId         String
  status             ArticleStatus    @default(planning)
  publishDate        DateTime?
  readinessDeadline  DateTime?
  seoScore           Int?
  wordpressPostId    Int?
  approvedById       String?
  approvedAt         DateTime?
  rejectedById       String?
  rejectedAt         DateTime?
  scheduleBatchId      String?
  scheduledSlotId      String?
  generationSource     String?
  // AI planning fields (populated when slot is promoted to article)
  articleAngle         String?       @db.Text
  seoKeywords          String[]      @default([])
  outline              Json?
  featuredImagePrompt  String?       @db.Text
  inlineImagePrompts   Json?
  videoIdea            String?       @db.Text
  metaDescription      String?       @db.Text
  // Shared Managed Agent session for social content generation across all platforms
  socialContentSessionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  topic                Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  category             Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  versions             ArticleVersion[]
  scheduledSlots       ScheduledArticleSlot[]
  research             ArticleResearch?
  assetRequests        ArticleAssetRequest[]
  automationRuns       ArticleAutomationRun[]
  pipelineEngineLogs   PipelineEngineLog[]
  socialPosts          SocialPost[]

  @@index([topicId])
  @@index([categoryId])
  @@index([status])
  @@index([isEditorsChoice])
  @@index([scheduleBatchId])
  @@index([scheduledSlotId])
}

/// Snapshot of article body before an update (important fields)
model ArticleVersion {
  id           String   @id @default(uuid())
  articleId    String
  title        String
  summary      String?
  content      Json?
  versionLabel String?
  createdBy    String?
  createdAt    DateTime @default(now())
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([createdAt])
}

enum AIAttemptStatus {
  success
  failed
}

enum AIAttemptType {
  planning
  research
  writing
  image_generation
}

/// AI generation attempts — one row per n8n call or redo
model AIAttempt {
  id          String          @id @default(uuid())
  articleId   String?
  slotId      String?
  type        AIAttemptType
  prompt      String?         @db.Text
  result      String?         @db.Text
  model       String
  status      AIAttemptStatus @default(success)
  isRedo      Boolean         @default(false)
  triggeredBy String?
  createdAt   DateTime        @default(now())

  @@index([articleId])
  @@index([slotId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

/// Content-operation events (separate from SystemLog user-activity)
model ContentLog {
  id         String   @id @default(uuid())
  /// category | topic | article | project | system
  type       String
  /// create | update | delete | archive | status_change
  action     String?
  message    String
  entityType String?
  entityId   String?
  metadata   Json?
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([type])
}

model Approval {
  id          String         @id @default(uuid())
  type        String
  status      ApprovalStatus @default(pending)
  requestedBy String
  createdAt   DateTime       @default(now())

  @@index([status])
}

enum ProjectPhaseSlug {
  build
  automation
}

enum WorkstreamStatus {
  not_started
  in_progress
  completed
  blocked
}

enum MilestoneStatus {
  not_started
  in_progress
  completed
  blocked
}

enum MilestoneType {
  build
  automation
}

enum BlockerSeverity {
  low
  medium
  high
  critical
}

enum BlockerStatus {
  open
  resolved
}

enum IdeaPriority {
  low
  medium
  high
}

enum IdeaStatus {
  new
  under_consideration
  accepted
  rejected
  parked
}

model ProjectPhase {
  id              String              @id @default(uuid())
  slug            ProjectPhaseSlug    @unique
  title           String
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  progressPercent Int                 @default(0)
  sortOrder       Int                 @default(0)
  workstreams     ProjectWorkstream[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([sortOrder])
}

model ProjectWorkstream {
  id              String             @id @default(uuid())
  phaseId         String
  name            String
  description     String?
  status          WorkstreamStatus   @default(not_started)
  progressPercent Int                @default(0)
  sortOrder       Int                @default(0)
  phase           ProjectPhase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  milestones      ProjectMilestone[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([phaseId])
  @@index([status])
  @@index([sortOrder])
}

model ProjectMilestone {
  id              String            @id @default(uuid())
  workstreamId    String
  title           String
  description     String?
  status          MilestoneStatus   @default(not_started)
  type            MilestoneType
  startDate       DateTime?
  endDate         DateTime?
  progressPercent Int               @default(0)
  sortOrder       Int               @default(0)
  workstream      ProjectWorkstream @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  blockers        ProjectBlocker[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workstreamId])
  @@index([type])
  @@index([status])
  @@index([sortOrder])
}

model ProjectBlocker {
  id          String            @id @default(uuid())
  milestoneId String?
  title       String
  description String?
  severity    BlockerSeverity   @default(medium)
  status      BlockerStatus     @default(open)
  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime          @updatedAt
  milestone   ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([milestoneId])
  @@index([status])
  @@index([severity])
}

model ProjectProgressReport {
  id                 String   @id @default(uuid())
  title              String
  summary            String
  buildProgress      Int
  automationProgress Int
  keyFocus           String?
  blockersSummary    String?
  createdAt          DateTime @default(now())
}

model IdeaBacklog {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    IdeaPriority @default(medium)
  status      IdeaStatus   @default(new)
  tags        String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

// Scheduling Engine — Milestone 8
enum ScheduleBatchStatus {
  draft
  scheduled
  running
  paused
  completed
  failed
}

enum ScheduledSlotStatus {
  planned
  sent_to_n8n
  generating
  completed
  failed
}

model ScheduleBatch {
  id              String               @id @default(uuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  postsPerDay     Int
  status          ScheduleBatchStatus  @default(draft)
  totalSlots      Int                  @default(0)
  completedSlots  Int                  @default(0)
  failedSlots     Int                  @default(0)
  sectionIds      String[]             @default([])
  categoryIds     String[]             @default([])
  excludeTopicIds String[]             @default([])
  /// "n8n_unavailable" | "manual" | null
  pauseReason     String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  slots           ScheduledArticleSlot[]

  @@index([status])
  @@index([createdAt])
}

model ScheduledArticleSlot {
  id             String              @id @default(uuid())
  batchId        String
  articleId      String?
  sectionId      String?
  categoryId     String
  topicId        String
  scheduledDate  DateTime
  position       Int                 @default(0)
  status         ScheduledSlotStatus @default(planned)
  n8nExecutionId String?
  errorMessage   String?
  planningData   Json?
  triggeredAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  batch          ScheduleBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  article        Article?            @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([articleId])
  @@index([topicId])
  @@index([status])
  @@index([scheduledDate])
}

// Pipeline Engine — batch article automation

enum PipelineEngineStatus {
  idle
  running
  paused
}

/// One row per engine type: "research" | "writing" | "images"
model PipelineEngine {
  id                 String               @id    // "research" | "writing" | "images"
  status             PipelineEngineStatus @default(idle)
  pauseReason        String?
  currentArticleId   String?
  currentStep        String?              // "research" | "writing" | "assets"
  delayMinutes       Int                  @default(0) // wait N minutes between jobs
  lastJobCompletedAt DateTime?
  totalProcessed     Int                  @default(0)
  totalFailed        Int                  @default(0)
  updatedAt          DateTime             @updatedAt
}

/// Immutable log entry for each article step processed by the pipeline engine
model PipelineEngineLog {
  id          String    @id @default(uuid())
  engineId    String?   // "research" | "writing" | "images" (null = legacy)
  articleId   String
  steps       String[]
  status      String    // "completed" | "failed"
  error       String?
  startedAt   DateTime
  completedAt DateTime?
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([engineId])
  @@index([articleId])
  @@index([status])
  @@index([startedAt])
}

// Article Automation — Milestone 9

/// One-to-one research result per article
model ArticleResearch {
  id            String   @id @default(uuid())
  articleId     String   @unique
  sources       Json?
  notes         Json?
  keyFacts      Json?
  searchQueries Json?
  summary       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

enum AssetRequestType {
  featured_image
  inline_image
  diagram
  chart
  social_asset
}

enum AssetRequestStatus {
  pending
  generating
  completed
  failed
}

/// One row per image/asset that needs to be generated for an article
model ArticleAssetRequest {
  id           String             @id @default(uuid())
  articleId    String
  type         AssetRequestType
  prompt       String             @db.Text
  placementKey String
  status       AssetRequestStatus @default(pending)
  imageUrl     String?
  errorMessage String?
  version      Int                @default(1)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  article      Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  history      ArticleAssetHistory[]

  @@index([articleId])
  @@index([status])
}

/// Previous versions of a generated asset image (kept when a redo replaces the image)
model ArticleAssetHistory {
  id             String              @id @default(uuid())
  assetRequestId String
  imageUrl       String
  prompt         String?             @db.Text
  version        Int
  createdAt      DateTime            @default(now())
  assetRequest   ArticleAssetRequest @relation(fields: [assetRequestId], references: [id], onDelete: Cascade)

  @@index([assetRequestId])
}

enum AutomationRunWorkflow {
  research
  writing
  image_generation
}

enum AutomationRunStatus {
  running
  completed
  failed
}

/// Audit trail for every n8n workflow execution triggered for an article
model ArticleAutomationRun {
  id             String                @id @default(uuid())
  articleId      String
  workflowType   AutomationRunWorkflow
  n8nExecutionId String?
  status         AutomationRunStatus   @default(running)
  input          Json?
  output         Json?
  errorMessage   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  article        Article               @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([workflowType])
  @@index([status])
}

// ─── Social Content Pipeline ──────────────────────────────────────────────────

enum SocialCampaignStatus {
  pending
  running
  reviewing
  done
  failed
}

enum SocialPlatform {
  instagram_carousel
  instagram_story
  linkedin
  twitter
}

enum SocialPostStatus {
  pending
  content_generating
  content_ready
  exporting
  uploaded
  scheduling
  scheduled
  failed
}

model SocialCampaign {
  id          String               @id @default(uuid())
  weekStart   DateTime
  weekEnd     DateTime
  status      SocialCampaignStatus @default(pending)
  // Settings captured at creation time (copied from SocialSettings defaults)
  maxPostsPerPlatform Json
  campaignBrief       String?  @db.Text
  editorsChoiceOnly   Boolean  @default(false)
  includeSections     String[] @default([])
  // Managed Agent session ID used for this campaign's approval (audit trail)
  approvalSessionId   String?
  posts     SocialPost[]
  logs      SocialCampaignLog[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status])
  @@index([weekStart])
}

model SocialPost {
  id             String           @id @default(uuid())
  campaignId     String
  articleId      String
  platform       SocialPlatform
  status         SocialPostStatus @default(pending)
  // Ordered slide IDs; carousel: 4-7 slides; story/linkedin: 1 element
  slideIds       String[]         @default([])
  // Caption editable by user before scheduling; AI-generated initially
  generatedText  String?          @db.Text
  hashtags       String[]         @default([])
  // Ordered CDN URLs matching slideIds order (empty for Twitter)
  imageUrls      String[]         @default([])
  // All {{PLACEHOLDER}} values from AI (HOOK, QUOTE, STAT_N, etc.)
  placeholders   Json?
  // Export progress tracking (enables "slide X/Y" UI)
  exportProgress Int              @default(0)
  exportTotal    Int              @default(0)
  bufferPostId   String?
  scheduledAt    DateTime?
  analyticsData  Json?
  errorMessage   String?          @db.Text
  campaign       SocialCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  article        Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([campaignId])
  @@index([articleId])
  @@index([platform])
  @@index([status])
}

/// Detailed trace of every pipeline step — used for the live run log UI
model SocialCampaignLog {
  id         String   @id @default(uuid())
  campaignId String
  postId     String?
  // e.g. 'approval_fetch', 'approval_ai_send', 'approval_ai_receive', 'content_session',
  //      'content_ai_send', 'content_ai_receive', 'export_slide', 'export_upload', 'schedule_buffer'
  step       String
  // 'running' | 'done' | 'error'
  status     String   @default("running")
  // Human-readable summary shown in the UI
  message    String?  @db.Text
  // Raw input data (message sent to AI, export params, Buffer payload…)
  input      Json?
  // Raw output data (AI response, S3 URL, Buffer post ID…)
  output     Json?
  campaign   SocialCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([campaignId])
  @@index([postId])
  @@index([step])
}

/// Global defaults + Buffer profile IDs + Anthropic Managed Agent references
model SocialSettings {
  id                          String   @id @default("singleton")
  // Anthropic Managed Agent IDs (created manually in Anthropic Console)
  approvalAgentId             String?
  approvalEnvironmentId       String?
  // Content generation agent — separate agent, one session per post
  contentAgentId              String?
  contentEnvironmentId        String?
  // Buffer profile IDs
  instagramCarouselProfileId  String?
  instagramStoryProfileId     String?
  linkedinProfileId           String?
  twitterProfileId            String?
  // Default max posts per platform per week (overridable per campaign)
  defaultMaxInstagramCarousel Int      @default(3)
  defaultMaxInstagramStory    Int      @default(5)
  defaultMaxLinkedin          Int      @default(3)
  defaultMaxTwitter           Int      @default(7)
  // Per-platform posting windows; day bitmask (bit 0=Sun … bit 6=Sat)
  instagramCarouselDays         Int      @default(28)
  instagramCarouselWindowStart  String   @default("10:00")
  instagramCarouselWindowEnd    String   @default("10:00")
  instagramStoryDays            Int      @default(62)
  instagramStoryWindowStart     String   @default("08:00")
  instagramStoryWindowEnd       String   @default("20:00")
  linkedinDays                  Int      @default(20)
  linkedinWindowStart           String   @default("09:00")
  linkedinWindowEnd             String   @default("09:00")
  twitterDays                   Int      @default(42)
  twitterWindowStart            String   @default("10:00")
  twitterWindowEnd              String   @default("10:00")
  lookbackDays                Int      @default(30)
  // UTC offset for posting windows (e.g. -4 for US Eastern Daylight Time)
  timezoneOffset              Int      @default(0)
  // When false: pipeline auto-schedules immediately after upload (no review pause)
  requireReview               Boolean  @default(true)
  disabledTemplates           String[] @default([])
  updatedAt                   DateTime @updatedAt
}

/// Runtime state for the ongoing Anthropic Managed Agent approval session
model SocialAiMemory {
  id                   String   @id @default("singleton")
  // Active session ID — reused across multiple campaigns; null = create new session next run
  activeSessionId      String?
  // How many campaigns have been approved in this session
  sessionCampaignCount Int      @default(0)
  // Rotate to a new session after this many campaigns
  sessionRotateAfter   Int      @default(10)
  // Handoff summary written by the agent at rotation; injected as first message in new session
  handoffSummary       String?  @db.Text
  updatedAt            DateTime @updatedAt
}
