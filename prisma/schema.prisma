generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Modoule
enum UserStatus {
  INACTIVE
  ACTIVE
  BLOCKED
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  password        String?
  country         String?
  timezone        String?
  name            String?
  roleId          String
  status          UserStatus  @default(INACTIVE) // Status of the invitation
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastSignInAt    DateTime?
  emailVerifiedAt DateTime?
  isTrashed       Boolean     @default(false)
  avatar          String?
  invitedByUserId String?
  isProtected     Boolean     @default(false) // Prevents deletion/modification
  role            UserRole    @relation(fields: [roleId], references: [id])
  systemLog       SystemLog[]
  accounts        Account[]
  Session         Session[]

  // Indexes for efficient querying
  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
}

model UserRole {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String               @unique
  description     String?
  isTrashed       Boolean              @default(false)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  isProtected     Boolean              @default(false)
  isDefault       Boolean              @default(false)
  users           User[]
  permissions     UserRolePermission[]
}

model UserPermission {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String
  description     String?
  createdByUserId String?
  createdAt       DateTime             @default(now())
  roles           UserRolePermission[]
}

model UserRolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       UserRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission UserPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemLog {
  id          String   @id @default(uuid())
  userId      String
  createdAt   DateTime @default(now())
  entityId    String?
  entityType  String?
  event       String?
  description String?
  ipAddress   String?
  meta        String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SystemSetting {
  id             String  @id @default(uuid())
  name           String  @default("My Company")
  logo           String?
  active         Boolean @default(true)
  address        String?
  websiteURL     String?
  supportEmail   String?
  supportPhone   String?
  language       String  @default("en")
  timezone       String  @default("UTC")
  currency       String  @default("USD")
  currencyFormat String  @default("$ {value}")

  socialFacebook  String?
  socialTwitter   String?
  socialInstagram String?
  socialLinkedIn  String?
  socialPinterest String?
  socialYoutube   String?

  notifyStockEmail               Boolean  @default(true)
  notifyStockWeb                 Boolean  @default(true)
  notifyStockThreshold           Int      @default(10)
  notifyStockRoleIds             String[]
  notifyNewOrderEmail            Boolean  @default(true)
  notifyNewOrderWeb              Boolean  @default(true)
  notifyNewOrderRoleIds          String[]
  notifyOrderStatusUpdateEmail   Boolean  @default(true)
  notifyOrderStatusUpdateWeb     Boolean  @default(true)
  notifyOrderStatusUpdateRoleIds String[]
  notifyPaymentFailureEmail      Boolean  @default(true)
  notifyPaymentFailureWeb        Boolean  @default(true)
  notifyPaymentFailureRoleIds    String[]
  notifySystemErrorFailureEmail  Boolean  @default(true)
  notifySystemErrorWeb           Boolean  @default(true)
  notifySystemErrorRoleIds       String[]
}

// Content hierarchy — Section → Category → Topic → Article
enum SectionStatus {
  active
  archived
}

enum CategoryStatus {
  active
  archived
}

enum TopicStatus {
  active
  archived
}

/// Pipeline stage (single article status)
enum ArticleStatus {
  planning
  research
  writing
  assets
  review
  approval
  scheduling
  publishing
  post_publish
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model Section {
  id                    String        @id @default(uuid())
  name                  String
  slug                  String        @unique
  description           String?
  summary               String?
  icon                  String?
  status                SectionStatus @default(active)
  characterName         String?
  characterBackground   String?
  characterRole         String?
  characterAge          String?
  characterBiography    String?       @db.Text
  characterTone         String?
  characterWritingStyle String?       @db.Text
  characterSampleVoice  String?       @db.Text
  characterPersona      String?       @db.Text
  characterImage        String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  categories            Category[]

  @@index([status])
  @@index([slug])
}

model Category {
  id          String         @id @default(uuid())
  name        String
  description String?
  status      CategoryStatus @default(active)
  sectionId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  section     Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  topics      Topic[]
  articles    Article[]

  @@index([status])
  @@index([sectionId])
}

model Topic {
  id            String      @id @default(uuid())
  name          String
  description   String?
  categoryId    String
  targetKeyword String?
  status        TopicStatus @default(active)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  articles      Article[]

  @@index([categoryId])
  @@index([status])
}

model Article {
  id                 String           @id @default(uuid())
  title              String
  /// TipTap / ProseMirror doc: { type: "doc", content: [...] }
  summary            String?
  content            Json?
  featuredImage      String?
  galleryImages      String[]         @default([])
  videoUrl           String?
  isEditorsChoice    Boolean          @default(false)
  views              Int              @default(0)
  likes              Int              @default(0)
  commentsCount      Int              @default(0)
  topicId            String
  categoryId         String
  status             ArticleStatus    @default(planning)
  publishDate        DateTime?
  readinessDeadline  DateTime?
  seoScore           Int?
  wordpressPostId    Int?
  scheduleBatchId    String?
  scheduledSlotId    String?
  generationSource   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  topic              Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  category           Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  versions           ArticleVersion[]

  @@index([topicId])
  @@index([categoryId])
  @@index([status])
  @@index([isEditorsChoice])
  @@index([scheduleBatchId])
  @@index([scheduledSlotId])
}

/// Snapshot of article body before an update (important fields)
model ArticleVersion {
  id           String   @id @default(uuid())
  articleId    String
  title        String
  summary      String?
  content      Json?
  versionLabel String?
  createdBy    String?
  createdAt    DateTime @default(now())
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([createdAt])
}

enum AIAttemptStatus {
  success
  failed
}

/// AI generation attempts (populated from Milestone 9)
model AIAttempt {
  id        String          @id @default(uuid())
  articleId String?
  prompt    String          @db.Text
  result    String          @db.Text
  model     String
  status    AIAttemptStatus @default(success)
  createdAt DateTime        @default(now())

  @@index([articleId])
  @@index([status])
  @@index([createdAt])
}

/// Content-operation events (separate from SystemLog user-activity)
model ContentLog {
  id         String   @id @default(uuid())
  /// category | topic | article | project | system
  type       String
  /// create | update | delete | archive | status_change
  action     String?
  message    String
  entityType String?
  entityId   String?
  metadata   Json?
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([type])
}

model Approval {
  id          String         @id @default(uuid())
  type        String
  status      ApprovalStatus @default(pending)
  requestedBy String
  createdAt   DateTime       @default(now())

  @@index([status])
}

enum ProjectPhaseSlug {
  build
  automation
}

enum WorkstreamStatus {
  not_started
  in_progress
  completed
  blocked
}

enum MilestoneStatus {
  not_started
  in_progress
  completed
  blocked
}

enum MilestoneType {
  build
  automation
}

enum BlockerSeverity {
  low
  medium
  high
  critical
}

enum BlockerStatus {
  open
  resolved
}

enum IdeaPriority {
  low
  medium
  high
}

enum IdeaStatus {
  new
  under_consideration
  accepted
  rejected
  parked
}

model ProjectPhase {
  id              String              @id @default(uuid())
  slug            ProjectPhaseSlug    @unique
  title           String
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  progressPercent Int                 @default(0)
  sortOrder       Int                 @default(0)
  workstreams     ProjectWorkstream[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([sortOrder])
}

model ProjectWorkstream {
  id              String             @id @default(uuid())
  phaseId         String
  name            String
  description     String?
  status          WorkstreamStatus   @default(not_started)
  progressPercent Int                @default(0)
  sortOrder       Int                @default(0)
  phase           ProjectPhase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  milestones      ProjectMilestone[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([phaseId])
  @@index([status])
  @@index([sortOrder])
}

model ProjectMilestone {
  id              String            @id @default(uuid())
  workstreamId    String
  title           String
  description     String?
  status          MilestoneStatus   @default(not_started)
  type            MilestoneType
  startDate       DateTime?
  endDate         DateTime?
  progressPercent Int               @default(0)
  sortOrder       Int               @default(0)
  workstream      ProjectWorkstream @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  blockers        ProjectBlocker[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workstreamId])
  @@index([type])
  @@index([status])
  @@index([sortOrder])
}

model ProjectBlocker {
  id          String            @id @default(uuid())
  milestoneId String?
  title       String
  description String?
  severity    BlockerSeverity   @default(medium)
  status      BlockerStatus     @default(open)
  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime          @updatedAt
  milestone   ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([milestoneId])
  @@index([status])
  @@index([severity])
}

model ProjectProgressReport {
  id                 String   @id @default(uuid())
  title              String
  summary            String
  buildProgress      Int
  automationProgress Int
  keyFocus           String?
  blockersSummary    String?
  createdAt          DateTime @default(now())
}

model IdeaBacklog {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    IdeaPriority @default(medium)
  status      IdeaStatus   @default(new)
  tags        String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

// Scheduling Engine — Milestone 8
enum ScheduleBatchStatus {
  draft
  scheduled
  running
  paused
  completed
  failed
}

enum ScheduledSlotStatus {
  planned
  sent_to_n8n
  generating
  completed
  failed
}

model ScheduleBatch {
  id              String               @id @default(uuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  postsPerDay     Int
  status          ScheduleBatchStatus  @default(draft)
  totalSlots      Int                  @default(0)
  completedSlots  Int                  @default(0)
  failedSlots     Int                  @default(0)
  sectionIds      String[]             @default([])
  categoryIds     String[]             @default([])
  excludeTopicIds String[]             @default([])
  /// "n8n_unavailable" | "manual" | null
  pauseReason     String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  slots           ScheduledArticleSlot[]

  @@index([status])
  @@index([createdAt])
}

model ScheduledArticleSlot {
  id             String              @id @default(uuid())
  batchId        String
  articleId      String?
  sectionId      String?
  categoryId     String
  topicId        String
  scheduledDate  DateTime
  position       Int                 @default(0)
  status         ScheduledSlotStatus @default(planned)
  n8nExecutionId String?
  errorMessage   String?
  planningData   Json?
  triggeredAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  batch          ScheduleBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([topicId])
  @@index([status])
  @@index([scheduledDate])
}
